# ============================================================================
# AtoM Docker Environment Configuration
# ============================================================================
# Copy this file to .env and customize for your environment
# cp .env.example .env
# ============================================================================

# ============================================================================
# Database Configuration (Percona/MariaDB/MySQL)
# ============================================================================
DB_HOST=db
DB_PORT=3306
MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_DATABASE=atom_db
MYSQL_USER=atom_user
MYSQL_PASSWORD=atompassword123

# ============================================================================
# Memcached Cache Configuration
# ============================================================================
MEMCACHED_HOST=cache
MEMCACHED_PORT=11211
MEMCACHED_MEMORY=256

# ============================================================================
# Gearman Job Server Configuration
# ============================================================================
GEARMAN_HOST=gearmand
GEARMAN_PORT=4730
GEARMAN_WORKER_COUNT=3

# ============================================================================
# Elasticsearch Configuration
# ============================================================================
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ============================================================================
# AtoM Application Configuration
# ============================================================================
# Admin account credentials
ATOM_ADMIN_USERNAME=admin
ATOM_ADMIN_EMAIL=admin@example.com
ATOM_ADMIN_PASSWORD=admin123

# Site configuration
ATOM_SITE_TITLE=Access to Memory
ATOM_SITE_DESCRIPTION=An open-source archival description software
ATOM_SITE_BASE_URL=http://127.0.0.1
ATOM_TIMEZONE=UTC

# ============================================================================
# PHP Configuration
# ============================================================================
# Memory limit for PHP (increase for large file uploads)
ATOM_PHP_MEMORY_LIMIT=512M

# Maximum file upload size
ATOM_PHP_UPLOAD_MAX_FILESIZE=256M

# PHP script execution time (in seconds)
ATOM_PHP_MAX_EXECUTION_TIME=300

# ============================================================================
# Port Configuration
# ============================================================================
# Main AtoM application port
ATOM_PORT=8080

# ============================================================================
# Performance Tuning
# ============================================================================
# MySQL innodb buffer pool size
MYSQL_INNODB_BUFFER_POOL_SIZE=1G

# MySQL max allowed packet
MYSQL_MAX_ALLOWED_PACKET=256M

# ============================================================================
# Advanced Configuration
# ============================================================================
# Number of worker processes for Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m